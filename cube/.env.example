# Optional host port for MCP SSE (default 3012).
MCP_SERVE_HOST_PORT=3012
# Public URL path prefix when proxied under mcp.seleric.com/serve/ (empty for dedicated subdomain root).
MCP_PUBLIC_PATH=/serve

CUBEJS_DEV_MODE=true
CUBEJS_DB_TYPE=clickhouse
CUBEJS_DB_HOST=clickhouse.seleric.com
CUBEJS_DB_PORT=8123
# Default database; cubes use gold.* and serve.* qualified table names.
CUBEJS_DB_NAME=gold
CUBEJS_DB_USER=
CUBEJS_DB_PASS=
CUBEJS_DB_CLICKHOUSE_READONLY=true
CUBEJS_API_SECRET=
CUBEJS_SCHEMA_PATH=model
CUBEJS_WEB_SOCKETS=true
CUBEJS_DB_QUERY_DEFAULT_LIMIT=50000
CUBEJS_DB_QUERY_LIMIT=50000
