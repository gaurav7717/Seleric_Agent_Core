# --- Cube semantic layer (only data path) ---
# In-project Cube: `docker compose up -d` serves ./cube/model at 127.0.0.1:4001.
# ClickHouse credentials live in ./cube/.env (see ./cube/.env.example).
CUBE_API_URL=http://127.0.0.1:4001
# Preferred: static bearer key understood by cube-serve
SELERIC_API_KEY=
# Fallback: HS256 JWT signing secret (must match CUBEJS_API_SECRET in ./cube/.env)
CUBEJS_API_SECRET=

# --- Action execution (Meta Ads via Pipeboard) ---
PIPEBOARD_MCP_URL=https://meta-ads.mcp.pipeboard.co
PIPEBOARD_TOKEN=
# Global kill switch for all write actions. Must be exactly "true" to allow commits.
WRITE_ENABLED=false

# --- Gateway ---
# Shared bearer token required on the streamable-http transport (stdio trusts the local process)
MCP_SERVICE_TOKEN=
# HMAC secret for action confirmation tokens
APPROVAL_SECRET=change-me
# Scopes granted to the caller (comma-separated). Read scopes plus the pause action scope by default.
SELERIC_MCP_SCOPES=metrics:read,meta_ads:write:status

# --- Storage ---
# SQLite database path, relative to the project root
SELERIC_MCP_DB=var/seleric_mcp.db

# --- Behavior tunables (all optional; defaults shown, nothing hardcoded) ---
# Term-resolution confidence bands (SequenceMatcher ratio, 0..1)
#SELERIC_RESOLVE_AUTO_THRESHOLD=0.85
#SELERIC_RESOLVE_AMBIGUOUS_THRESHOLD=0.60
#SELERIC_RESOLVE_RUNNER_UP_MARGIN=0.05
# Query limits / timeouts
#SELERIC_DEFAULT_ROW_LIMIT=500
#SELERIC_MAX_ROW_LIMIT=5000
#SELERIC_CUBE_TIMEOUT_S=30
# Stored query results and action idempotency windows
#SELERIC_RESULT_TTL_MINUTES=60
#SELERIC_IDEMPOTENCY_WINDOW_HOURS=24
# Insight engine
#SELERIC_TOP_MOVERS_LIMIT=10
#SELERIC_ANOMALY_SIGMA=3.0
#SELERIC_ANOMALY_MIN_POINTS=14
# Freshness resource cache
#SELERIC_FRESHNESS_CACHE_TTL_S=600

# --- Terminal chat client (scripts/chat_client.py) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com
AZURE_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Max tool rounds per user turn; agent policy text lives in scripts/agent_policy.md
#CHAT_MAX_TOOL_ROUNDS=12
