# Secrets only. Non-secret settings live in config.yaml
# (cube URL, scopes, tunables, Azure endpoint/deployment, etc.).
# Any key in config.yaml can still be overridden via env / .env.local.

# --- Cube auth ---
# Preferred: static bearer key understood by cube-serve
SELERIC_API_KEY=
# Fallback: HS256 JWT signing secret (must match CUBEJS_API_SECRET in mage-ai/infra/cube/.env)
CUBEJS_API_SECRET=

# --- Pipeboard (Meta Ads actions) ---
PIPEBOARD_TOKEN=

# --- Gateway ---
# Shared bearer token for streamable-http (stdio trusts the local process)
MCP_SERVICE_TOKEN=
# HMAC secret for action confirmation tokens
APPROVAL_SECRET=change-me

# --- Terminal / web chat (Azure OpenAI) ---
# Endpoint / deployment / api_version: config.yaml → azure
AZURE_OPENAI_API_KEY=

# --- OpenMetadata MCP (metadata context only; not used for metric math) ---
# See docs/openmetadata_mcp.md — wire in Cursor MCP config, not required for Cube queries.
OPENMETADATA_BASE_URL=http://127.0.0.1:8585
# JWT from: cd mage-ai && py infra/openmetadata/get_ingestion_jwt.py
OM_JWT_OR_PAT=
